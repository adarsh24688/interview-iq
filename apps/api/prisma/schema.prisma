// Interview IQ database schema.
// MongoDB (Atlas in production). Access control lives in the service layer: the API is the
// only database client and enforces ownership on every query. See CLAUDE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Seniority {
  junior
  mid
  senior
  lead
  principal
}

enum InterviewStatus {
  setup
  in_progress
  completed
}

model User {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  refreshTokens RefreshToken[]
  resumes       Resume[]
  profiles      Profile[]
  interviews    Interview[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @map("user_id") @db.ObjectId
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Resume {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @map("user_id") @db.ObjectId
  filename    String
  mimeType    String    @map("mime_type")
  sizeBytes   Int       @map("size_bytes")
  storagePath String    @map("storage_path")
  rawText     String?   @map("raw_text")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile?

  @@index([userId])
  @@map("resumes")
}

model Profile {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @map("user_id") @db.ObjectId
  resumeId   String   @unique @map("resume_id") @db.ObjectId
  summary    String
  skills     String[]
  experience Json
  createdAt  DateTime @default(now()) @map("created_at")
  editedAt   DateTime @updatedAt @map("edited_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume     Resume      @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  interviews Interview[]

  @@index([userId])
  @@map("profiles")
}

model Interview {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  userId         String          @map("user_id") @db.ObjectId
  profileId      String          @map("profile_id") @db.ObjectId
  role           String
  seniority      Seniority
  jobDescription String?         @map("job_description")
  status         InterviewStatus @default(setup)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile    Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  questions  Question[]
  answers    Answer[]
  assessment Assessment?

  @@index([userId])
  @@index([profileId])
  @@map("interviews")
}

model Question {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  interviewId String @map("interview_id") @db.ObjectId
  order       Int
  text        String

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  answer    Answer?

  @@unique([interviewId, order])
  @@index([interviewId])
  @@map("questions")
}

model Answer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  interviewId String   @map("interview_id") @db.ObjectId
  questionId  String   @unique @map("question_id") @db.ObjectId
  text        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question  Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([interviewId, questionId])
  @@index([interviewId])
  @@map("answers")
}

model Assessment {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  interviewId        String   @unique @map("interview_id") @db.ObjectId
  overallScore       Int      @map("overall_score")
  relevanceScore     Int      @map("relevance_score")
  clarityScore       Int      @map("clarity_score")
  structureScore     Int      @map("structure_score")
  communicationScore Int      @map("communication_score")
  strengths          String[]
  improvements       String[]
  improvedExample    Json     @map("improved_example")
  createdAt          DateTime @default(now()) @map("created_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("assessments")
}
