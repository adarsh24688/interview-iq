# =========================================================
# Interview IQ environment configuration
# Copy this file to apps/api/.env and fill real values.
# Never commit a real .env file.
# =========================================================

# ---------- Runtime ----------
NODE_ENV=development
PORT=4000
# Comma separated list of allowed browser origins (the Next.js app).
CORS_ORIGIN=http://localhost:3000

# ---------- Database (MongoDB Atlas via Prisma) ----------
# Atlas: Connect, Drivers, copy the connection string. Include a database name in the path.
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/interview_iq?retryWrites=true&w=majority

# ---------- File storage (local disk) ----------
# Uploaded resumes are stored here. The resume text is saved in the database, so the raw
# file blob is not read back by any flow.
LOCAL_STORAGE_DIR=.storage

# ---------- Auth (custom JWT) ----------
# Generate each secret with: openssl rand -base64 48
# Required to be at least 32 characters in production.
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- AI provider ----------
# openai or mock. Set to mock to run the full flow with zero external keys.
AI_PROVIDER=mock
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# ---------- Uploads ----------
MAX_FILE_SIZE_MB=5

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# =========================================================
# Frontend (apps/web). Copy to apps/web/.env.local.
# Only NEXT_PUBLIC_ values reach the browser.
# =========================================================
NEXT_PUBLIC_API_URL=http://localhost:4000
